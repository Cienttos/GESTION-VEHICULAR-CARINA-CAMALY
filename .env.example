# Opcional: Google Places API Key para reseñas reales
# Si no se configura, se usan reseñas de demostración
# 1. Ve a https://console.cloud.google.com/
# 2. Crea un proyecto o selecciona uno existente
# 3. Habilita "Places API" 
# 4. Crea una clave API y restringela por HTTP referrers (tu dominio en Vercel)
# 5. Copia la clave aquí y en Vercel (Settings > Environment Variables)
GOOGLE_API_KEY=

# Opcional: Place ID de Google Maps (se detecta automáticamente)
# GOOGLE_PLACE_ID=ChIJK9xR3M7ivJUR1HCGFjOJt8k
