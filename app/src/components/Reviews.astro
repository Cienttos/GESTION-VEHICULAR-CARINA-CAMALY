        </svg>
        <svg class="board-star board-star-5" viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
          <path d="M20 2 L25 15 L38 15 L27 23 L31 37 L20 28 L9 37 L13 23 L2 15 L15 15 Z" stroke="#d4b860" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" fill="none" opacity="0.3"/>
        </svg>

        <svg class="board-msg board-msg-2" viewBox="0 0 100 35" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
          <text x="50" y="18" text-anchor="middle" font-family="'Caveat', cursive" font-size="22" font-weight="700" fill="var(--board-dark)" opacity="0.28">+40</text>
          <text x="50" y="34" text-anchor="middle" font-family="'Patrick Hand', cursive" font-size="13" fill="var(--board-medium)" opacity="0.24">clientes satisfechos</text>
        </svg>
        <svg class="board-msg board-msg-3" viewBox="0 0 130 50" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
          <text x="65" y="25" text-anchor="middle" font-family="'Caveat', cursive" font-size="30" font-weight="700" fill="var(--board-dark)" opacity="0.28">100%</text>
          <text x="65" y="48" text-anchor="middle" font-family="'Patrick Hand', cursive" font-size="18" fill="var(--board-medium)" opacity="0.24">compromiso</text>
        </svg>

        <div class="board-title-zone-new">
          <h2 class="board-main-title-new">Opiniones de Clientes</h2>
        </div>

        <div class="reviews-truck-wrap" id="reviews-truck-wrap">
          <div class="reviews-truck" id="reviews-truck">
            <div class="truck-body">
              <img src="/principal.svg" alt="" class="truck-img" aria-hidden="true" />
              <div class="truck-cargo-zone">
                <div class="cargo-line cargo-line-1"></div>
                <div class="cargo-line cargo-line-2"></div>
              </div>
            </div>
            <div class="truck-wheels">
              <div class="truck-wheel truck-wheel-1"><div class="wheel-hub"></div></div>
              <div class="truck-wheel truck-wheel-2"><div class="wheel-hub"></div></div>
              <div class="truck-wheel truck-wheel-3"><div class="wheel-hub"></div></div>
            </div>
          </div>
          <div class="reviews-grid" id="reviews-container">
            <div class="reviews-loading">
              <div>
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>
                <span>Cargando reseñas...</span>
              </div>
            </div>
          </div>
        </div>

        <div class="doodle-btn-wrap">
          <a href="https://www.google.com/maps/place//data=!4m4!3m3!1s0x680c3996c072cf2d:0x3b26dfa6fa60710d!9m1!1b1" target="_blank" class="reviews-btn-more">
