        <svg class="board-star board-star-1" viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
          <path d="M20 2 L25 15 L38 15 L27 23 L31 37 L20 28 L9 37 L13 23 L2 15 L15 15 Z" stroke="#d4b860" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" fill="none" opacity="0.35"/>
        </svg>
        <svg class="board-star board-star-2" viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
          <path d="M20 2 L25 15 L38 15 L27 23 L31 37 L20 28 L9 37 L13 23 L2 15 L15 15 Z" stroke="#d4b860" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" fill="none" opacity="0.25"/>
        </svg>
        <svg class="board-star board-star-3" viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
          <path d="M20 2 L25 15 L38 15 L27 23 L31 37 L20 28 L9 37 L13 23 L2 15 L15 15 Z" stroke="#d4b860" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" fill="none" opacity="0.3"/>
