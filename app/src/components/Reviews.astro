              <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92a5.06 5.06 0 0 1-2.2 3.32v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.1z" stroke="var(--brand)" stroke-width="1.5"/>
              <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" stroke="var(--brand)" stroke-width="1.5"/>
              <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" stroke="var(--brand)" stroke-width="1.5"/>
              <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" stroke="var(--brand)" stroke-width="1.5"/>
            </svg>
            <span class="reviews-btn-text">Ver Más</span>
            <svg class="reviews-btn-icon reviews-btn-icon-hover" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/>
              <polyline points="15 3 21 3 21 9"/>
              <line x1="10" y1="14" x2="21" y2="3"/>
            </svg>
          </a>
        </div>

      </div>

      <div class="board-tray-new">
        <div class="tray-accessories">
          <div class="eraser-on-tray">
            <div class="eraser-cap-ot"></div>
            <div class="eraser-body-ot">
              <span class="eraser-label-ot">CC GESTIÓN</span>
            </div>
            <div class="eraser-felt-ot"></div>
          </div>
           <div class="markers-standing">
             <div class="marker-standing marker-dark">
               <div class="ms-tip"></div>
               <div class="ms-body"></div>
               <div class="ms-cap"></div>
             </div>
             <div class="marker-standing marker-medium">
               <div class="ms-tip"></div>
               <div class="ms-body"></div>
               <div class="ms-cap"></div>
             </div>
             <div class="marker-standing marker-celeste">
               <div class="ms-tip"></div>
               <div class="ms-body"></div>
               <div class="ms-cap"></div>
             </div>
             <div class="marker-standing marker-amarillo">
               <div class="ms-tip"></div>
               <div class="ms-body"></div>
               <div class="ms-cap"></div>
             </div>
           </div>
